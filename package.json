{
  "name": "teamtrack",
  "private": true,
  "version": "1.1.0",
  "description": "TeamTrack - A Game Management App for Coaches and Team Managers",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:security": "eslint . --report-unused-disable-directives",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:e2e:headed": "playwright test --config=playwright.config.ts --headed",
    "test:e2e:ui": "playwright test --config=playwright.config.ts --ui",
    "test:e2e:debug": "playwright test --config=playwright.config.ts --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:setup": "node scripts/setup-e2e.mjs",
    "seed": "npx ampx seed",
    "repair:sharing-permissions": "tsx scripts/repair-shared-team-permissions.ts"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "^6.15.1",
    "idb": "^8.0.0",
    "@aws-sdk/client-dynamodb": "^3.965.0",
    "@aws-sdk/lib-dynamodb": "^3.965.0",
    "@aws-sdk/types": "^3.965.0",
    "aws-amplify": "^6.16.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-ga4": "^2.1.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.21.0",
    "@aws-amplify/backend-cli": "^1.8.2",
    "@aws-amplify/seed": "^1.1.1",
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/client-ses": "^3.965.0",
    "@aws-sdk/s3-request-presigner": "^3.1000.0",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.13",
    "aws-cdk-lib": "^2.234.1",
    "constructs": "^10.3.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "knip": "^5.82.1",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.1.0",
    "vitest": "^4.0.13"
  }
}
